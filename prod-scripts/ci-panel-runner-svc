#!/usr/bin/env bash
# CI Panel 扩展：给指定 runner 目录装/卸 systemd 服务的「特权小助手」。
#
# 为什么要它：daemon 以非 root 的 ci-runner 身份跑，用 `sudo -n`(非交互免密)调用本脚本。
# sudoers 只放行这一个脚本(见文件尾部安装说明)，把 root 权限收到极小面：
#   - 本脚本 root 所有、ci-runner 不可写 —— 否则等于把 root 送出去；
#   - 只往 /etc/systemd/system 写「自己生成的」unit，绝不执行 runner 目录里(ci-runner 可写)的脚本，
#     避免"改写 svc.sh/模板 → 被 root 执行"的提权；
#   - unit 用 User=<目录属主> 运行 runsvc.sh，runner 本身仍以普通用户身份跑，不涉 root；
#   - 目录必须在白名单根下且含 .runner，服务名严格校验。
#
# 用法：ci-panel-runner-svc install|uninstall|status <runner 目录绝对路径>
#      ci-panel-runner-svc set-env <runner 目录绝对路径> <base64(每行 KEY=VALUE)>
#      ci-panel-runner-svc preflight   （无副作用自检，回显版本与根目录）
set -euo pipefail

# 改动本脚本的行为时同步 +1，好让部署自检认出机器上装的是旧版本。
VERSION=1

ALLOWED_ROOT="/data/ci-runner" # 只允许操作这个根下的 runner；由 install-runner-privileges.sh 按需改写

action="${1:-}"
dir_in="${2:-}"

die() {
  echo "ci-panel-runner-svc: $*" >&2
  exit 1
}

arg3="${3:-}"

# preflight：无副作用自检。部署脚本(和 daemon)据此确认三件事——免密确实生效、装的是最新版
# 脚本、脚本的 ALLOWED_ROOT 与 daemon 的 CIP_SCAN_ROOTS 一致。不碰 systemd、不碰任何 runner
# 目录，所以不需要目录参数，必须放在下面的目录校验之前。
if [ "$action" = "preflight" ]; then
  echo "ok"
  echo "version=$VERSION"
  echo "allowed_root=$ALLOWED_ROOT"
  exit 0
fi

[ -n "$action" ] && [ -n "$dir_in" ] || die "用法: $0 install|uninstall|status|set-env <runner 目录> [载荷] | preflight"

# 规范化并校验目录
dir="$(readlink -f -- "$dir_in")" || die "无法解析目录: $dir_in"
case "$dir/" in
  "$ALLOWED_ROOT"/*) : ;;
  *) die "目录必须在 $ALLOWED_ROOT 下: $dir" ;;
esac
[ -d "$dir" ] || die "目录不存在: $dir"
[ -f "$dir/.runner" ] || die "不是 runner 目录(缺 .runner): $dir"
# runsvc.sh 随安装包放在 bin/ 下，官方 svc.sh install 会把它拷到顶层。这里同样从 bin/ 取源。
[ -f "$dir/bin/runsvc.sh" ] || die "缺 bin/runsvc.sh(安装包不完整): $dir"

# 以目录属主身份运行 runner(通常是 ci-runner)
run_user="$(stat -c %U "$dir")"
[ -n "$run_user" ] || die "取不到目录属主"

# 计算服务名：优先用已有 .service 文件，否则从 .runner 派生
if [ -f "$dir/.service" ] && [ -s "$dir/.service" ]; then
  svc="$(tr -d '[:space:]' < "$dir/.service")"
else
  url="$(sed -n 's/.*"gitHubUrl": *"\([^"]*\)".*/\1/p' "$dir/.runner" | head -1)"
  name="$(sed -n 's/.*"agentName": *"\([^"]*\)".*/\1/p' "$dir/.runner" | head -1)"
  owner_repo="$(printf '%s' "$url" | sed -E 's#^https?://[^/]+/##; s#/#-#g')"
  [ -n "$owner_repo" ] && [ -n "$name" ] || die "无法从 .runner 派生服务名"
  svc="actions.runner.${owner_repo}.${name}.service"
fi

# 严格校验服务名(与 daemon 侧 controlService 的正则一致)，防注入
printf '%s' "$svc" | grep -Eq '^actions\.runner\.[A-Za-z0-9._@-]+\.service$' \
  || die "非法的服务名: $svc"

unit="/etc/systemd/system/$svc"

case "$action" in
  install)
    # 把 bin/runsvc.sh 拷到顶层（官方 svc.sh 也是这么做的）；unit 的 ExecStart 指向它。
    # 以 runner 属主身份运行，所以拷完把属主/权限设对。
    cp -f "$dir/bin/runsvc.sh" "$dir/runsvc.sh" || die "拷贝 runsvc.sh 失败"
    chown "$run_user":"$run_user" "$dir/runsvc.sh" 2>/dev/null || true
    chmod 755 "$dir/runsvc.sh" || true

    # 用本脚本完全掌控的模板生成 unit，只插入已校验的 dir/user/svc
    cat > "$unit" <<EOF
[Unit]
Description=GitHub Actions Runner ($svc)
After=network-online.target
Wants=network-online.target

[Service]
ExecStart=$dir/runsvc.sh
User=$run_user
WorkingDirectory=$dir
KillMode=process
KillSignal=SIGTERM
TimeoutStopSec=5min
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF
    chmod 644 "$unit"
    # 写 .service 标记文件(daemon 扫描据此认单元名)，归属 runner 属主
    printf '%s\n' "$svc" > "$dir/.service"
    chown "$run_user":"$run_user" "$dir/.service" 2>/dev/null || true
    systemctl daemon-reload
    systemctl enable --now "$svc"
    echo "installed $svc"
    ;;
  uninstall)
    systemctl disable --now "$svc" 2>/dev/null || true
    rm -f "$unit"
    systemctl daemon-reload
    rm -f "$dir/.service"
    echo "uninstalled $svc"
    ;;
  status)
    systemctl is-active "$svc" 2>/dev/null || true
    ;;
  set-env)
    # 给 runner 的 systemd 单元写 drop-in 环境变量（复刻手动的 override.conf 做法）。
    # 载荷 = base64(每行一条 KEY=VALUE)，走 argv 传入：sudo 可审计、无 shell 元字符问题。
    # 本脚本只把载荷当「数据」渲染进 Environment=，绝不执行它——延续"绝不执行 runner
    # 目录内容"的提权红线。变量名严格白名单、值转义后用双引号包裹，防注入越权到别的指令。
    [ -f "$dir/.service" ] && [ -s "$dir/.service" ] || die "该 runner 未装 systemd 服务，无法设置环境变量"
    dropin_dir="/etc/systemd/system/$svc.d"
    decoded="$(printf '%s' "$arg3" | base64 -d 2>/dev/null)" || die "env 载荷 base64 解码失败"
    if [ -z "$decoded" ]; then
      # 空载荷 = 清空面板托管的所有环境变量：移除本 drop-in
      rm -f "$dropin_dir/override.conf"
      rmdir "$dropin_dir" 2>/dev/null || true
      systemctl daemon-reload
      echo "env cleared for $svc"
      exit 0
    fi
    tmp="$(mktemp)" || die "mktemp 失败"
    trap 'rm -f "$tmp"' EXIT
    printf '[Service]\n' > "$tmp"
    # 先用空 Environment= 重置，避免历史残留（整份覆盖本就干净，这是双保险）
    printf 'Environment=\n' >> "$tmp"
    while IFS= read -r line || [ -n "$line" ]; do
      [ -z "$line" ] && continue
      key="${line%%=*}"
      val="${line#*=}"
      printf '%s' "$key" | grep -Eq '^[A-Za-z_][A-Za-z0-9_]*$' || die "非法环境变量名: $key"
      # 值按行读取，天然不含换行；转义反斜杠与双引号后放进 Environment="K=V"。
      # 末尾再把 % 写成 %%：systemd 对 Environment= 做说明符展开，字面 % 不转义会被当成
      # 未知说明符导致整个 unit 解析失败（如代理密码里 URL 编码的 %40）。读回时 daemon 侧还原。
      esc_val="$(printf '%s' "$val" | sed 's/\\/\\\\/g; s/"/\\"/g; s/%/%%/g')"
      printf 'Environment="%s=%s"\n' "$key" "$esc_val" >> "$tmp"
    done <<EOF
$decoded
EOF
    mkdir -p "$dropin_dir"
    install -m 0644 -o root -g root "$tmp" "$dropin_dir/override.conf" || die "写 override.conf 失败"
    rm -f "$tmp"
    trap - EXIT
    # 只 daemon-reload 让 systemd 重读单元；重启由面板另走已白名单的 restart（带 busy 拦截）。
    systemctl daemon-reload
    echo "env set for $svc"
    ;;
  *)
    die "未知操作: $action(应为 install|uninstall|status|set-env|preflight)"
    ;;
esac
